@rendermode InteractiveServer

<div class="eco-card">
    <h3>@Titulo</h3>

    <p class="peso">Pontos por ação: <b>@Peso</b></p>

    <p class="total @(total >= 50 ? "meta" : "")">
        Total acumulado: <b>@total</b>
    </p>

    <div class="progress-bar">
        <div class="progress" style="width:@(Math.Min(total,100))%"></div>
    </div>

    <button @onclick="Incrementar">
        Registrar Atividade
    </button>

    @if (total >= 100)
    {
        <p class="mensagem">🌍 Você é um Herói do Planeta!</p>
    }
</div>

@code {
    [Parameter]
    public string Titulo { get; set; } = string.Empty;

    [Parameter]
    public int Peso { get; set; }

    private int total = 0;

    void Incrementar()
    {
        total += Peso;
    }
}